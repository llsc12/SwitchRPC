module libnx [system] {
	umbrella header "/opt/devkitpro/libnx/include/switch.h"
	export *
}

module std [system] {
	umbrella header "/opt/devkitpro/devkitA64/aarch64-none-elf/include/stdio.h"
	export *
}

module curl [system] {
	umbrella header "curl/curl_umbrella.h"
	export *
}

module json [system] {
	umbrella header "json/json_umbrella.h"
	export *
}
